---
import Base from '../layouts/Base.astro'
---
<Base title="Menu" description="Full menu at Poets Corner Café – breakfasts, lunches, cream teas, drinks and more in Sturminster Newton.">

  <div class="max-w-4xl mx-auto px-4 py-12">

    <h1 class="text-4xl font-bold text-stone-800 mb-2">Our Menu</h1>
    <p class="text-stone-500 mb-8">
      Home-cooked food and drink at very reasonable prices.
      We're happy to make small changes to suit your needs — just ask!
    </p>

    <!-- Menu photo -->
    <img src="/menu.jpg" alt="Poets Corner Café menu board" class="w-full rounded-2xl shadow-md mb-12 object-cover max-h-96" />

    {/* Helper component for a menu section */}
    {[
      {
        heading: '☕ Tea',
        items: [
          ['Pot of Tea (For One)', '£2.95'],
          ['Pot of Tea (For Two)', '£5.90'],
          ['Mug of Tea', '£2.75'],
          ['Mug of Herbal or Speciality Tea', '£2.75'],
        ],
      },
      {
        heading: '☕ Coffee',
        items: [
          ['Coffee', '£2.95'],
          ['Americano', '£2.95'],
          ['Decaffeinated Coffee', '£2.95'],
          ['Mug of Coffee', '£2.95'],
          ['Latte', '£2.95'],
          ['Cappuccino', '£2.95'],
          ['Mocha', '£2.95'],
        ],
      },
      {
        heading: '🍫 Hot Chocolate',
        items: [
          ['Hot Chocolate', '£2.95'],
          ['Hot Chocolate with Cream', '£3.20'],
        ],
      },
      {
        heading: '🥤 Milk Shakes',
        items: [
          ['Chocolate, Strawberry or Banana Milk Shake', '£2.95'],
          ['Milk Shake with Cream', '£3.20'],
        ],
      },
      {
        heading: '🧃 Cold Drinks',
        items: [
          ['Cans', '£1.95'],
          ['Fruit Spring Water', '£1.95'],
          ['Apple or Orange Juice', '£2.75'],
        ],
      },
      {
        heading: '🍳 Breakfast',
        items: [
          ['All Day English Breakfast', '£8.95'],
          ['Vegetarian Breakfast', '£8.95'],
        ],
      },
      {
        heading: '🥖 Rolls',
        items: [
          ['Fried Egg Roll', '£3.95'],
          ['Bacon Roll', '£4.95'],
          ['Sausage Roll', '£4.95'],
          ['Egg & Bacon Roll', '£6.50'],
          ['Egg, Bacon & Mushrooms Roll', '£6.95'],
        ],
      },
      {
        heading: '🍞 Rounds Of',
        items: [
          ['Toast & Butter', '£0.50'],
          ['Jam or Honey', '£0.50'],
        ],
      },
      {
        heading: '🥪 Sandwiches',
        note: null,
        items: [
          ['Salad Garnish', '£4.50'],
          ['Egg Mayonnaise', '£4.95'],
          ['Tuna Mayonnaise', '£4.95'],
          ['Cheese with Pickle / Tomato / Onion', '£4.95'],
          ['Chicken Mayonnaise', '£4.95'],
          ['Ham & Mustard', '£4.95'],
          ['Bacon, Lettuce & Tomato', '£6.50'],
          ['Prawn Mayonnaise', '£5.95'],
        ],
        extras: [
          ['Salad Garnish', '£0.99'],
          ['Coleslaw', '£0.99'],
        ],
      },
      {
        heading: '🥪 Tasty Toasted Sandwiches',
        note: 'All served with home-made coleslaw & salad garnish',
        items: [
          ['Cheddar Cheese with Onion or Tomato', '£7.95'],
          ['Stilton Cheese with Onion or Tomato', '£7.95'],
          ['Ham & Cheese & Tomato', '£8.95'],
        ],
      },
      {
        heading: '🍝 Pasta Dishes',
        note: 'All served with home-made coleslaw & salad garnish',
        items: [
          ['Onion and Tomato Sauce with Melted Cheese', '£8.95'],
          ['Onion and Tomato Sauce with Prawn', '£8.95'],
          ['Macaroni Cheese', '£8.95'],
        ],
      },
      {
        heading: '🍔 Burgers',
        items: [
          ['Beef Burger', '£4.95'],
          ['Chicken Burger', '£4.95'],
          ['Vegetarian Burger', '£4.95'],
          ['Burger with Cheese', '£5.50'],
        ],
      },
      {
        heading: '🍟 Dishes with Chips',
        items: [
          ['Eggs & Beans', '£8.95'],
          ['Sausage and Beans', '£8.95'],
          ['Ham & Egg', '£8.95'],
          ['Chips', '£3.75'],
        ],
      },
      {
        heading: '🥔 Baked Potatoes',
        note: 'All served with home-made coleslaw & salad garnish',
        items: [
          ['Cheese & Beans', '£8.95'],
          ['Egg Mayonnaise', '£8.95'],
          ['Tuna & Mayonnaise', '£8.95'],
          ['Chicken & Mayonnaise', '£6.95'],
          ['Garlic & Mushrooms', '£8.95'],
          ['Prawn Mayonnaise', '£9.50'],
        ],
      },
      {
        heading: '🧺 Platters',
        note: 'All served with salad, relish, home-made coleslaw and a roll',
        items: [
          ["Ploughman's Cheese", '£8.95'],
          ["Woodman's Sausage", '£8.95'],
          ["Market Man's Ham", '£8.95'],
        ],
      },
      {
        heading: '⭐ Oscar Special',
        items: [
          ['Cold Ham with chips, pickles, home-made coleslaw & salad', '£9.50'],
        ],
      },
      {
        heading: '🍆 Mousaka',
        items: [
          ['Mousaka served with salad & home-made coleslaw', '£9.95'],
          ['Mousaka served with chips', '£10.50'],
        ],
      },
    ].map(({ heading, note, items, extras }) => (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-amber-700 border-b border-amber-200 pb-2 mb-4">{heading}</h2>
        {note && <p class="text-stone-500 text-sm italic mb-3">{note}</p>}
        <div class="space-y-1">
          {items.map(([name, price]) => (
            <div class="flex justify-between items-baseline bg-white rounded-lg px-4 py-3 shadow-sm">
              <span class="text-stone-700 text-sm">{name}</span>
              <span class="text-stone-800 font-semibold text-sm ml-4 shrink-0">{price}</span>
            </div>
          ))}
          {extras && (
            <div class="mt-3">
              <p class="text-stone-500 text-xs font-medium uppercase tracking-wide mb-1 px-1">Extras</p>
              {extras.map(([name, price]) => (
                <div class="flex justify-between items-baseline bg-white rounded-lg px-4 py-3 shadow-sm mt-1">
                  <span class="text-stone-700 text-sm">{name}</span>
                  <span class="text-stone-800 font-semibold text-sm ml-4 shrink-0">{price}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      </section>
    ))}

    <div class="bg-amber-100 border border-amber-300 rounded-xl p-6 text-center">
      <p class="text-stone-700">
        Our menu changes regularly to make the most of seasonal produce.
        If you have any dietary requirements or allergies, please let us know —
        we're always happy to help.
      </p>
    </div>

  </div>

</Base>
