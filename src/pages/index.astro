---
import Base from '../layouts/Base.astro'
---
<Base title="Astro + Cloudflare Pages Template" description="A minimal Astro starter with Tailwind and Cloudflare Pages.">
  <main class="flex min-h-screen flex-col items-center justify-center gap-6 p-8 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">
      Astro + Cloudflare Pages
    </h1>
    <p class="max-w-md text-lg text-gray-500">
      A minimal starter template with Astro, Tailwind CSS, and Cloudflare Pages adapter.
      Replace this page with your own content.
    </p>
    <div class="flex gap-4 text-sm">
      <a
        href="https://docs.astro.build"
        class="rounded-lg border border-gray-200 px-4 py-2 font-medium hover:border-gray-400 transition-colors"
      >
        Astro docs
      </a>
      <a
        href="https://developers.cloudflare.com/pages"
        class="rounded-lg border border-gray-200 px-4 py-2 font-medium hover:border-gray-400 transition-colors"
      >
        Cloudflare Pages docs
      </a>
    </div>
  </main>
</Base>
