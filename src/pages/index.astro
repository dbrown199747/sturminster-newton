---
import Base from '../layouts/Base.astro'
---
<Base title="Home" description="Poets Corner Café in Sturminster Newton – serving breakfast, lunch, cream teas, and more for over 23 years in the heart of the Blackmore Vale.">

  <!-- Hero -->
  <section class="relative bg-stone-800 text-amber-50 overflow-hidden">
    <div class="absolute inset-0 bg-[url('/cafe.jpg')] bg-cover opacity-40" style="background-position: 50% 70%;"></div>
    <div class="relative max-w-5xl mx-auto px-4 py-20 sm:py-28 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4 text-amber-300">
        Welcome to Poets Corner Café
      </h1>
      <p class="text-lg sm:text-xl text-amber-100 max-w-2xl mx-auto mb-8">
        A warm, friendly café in the heart of Sturminster Newton, serving the
        Blackmore Vale for over 23&nbsp;years.
      </p>
      <div class="flex justify-center gap-3 flex-wrap">
        <a href="/menu" class="bg-amber-400 text-stone-800 font-semibold px-6 py-3 rounded-lg hover:bg-amber-300 transition-colors w-40 text-center">
          View Our Menu
        </a>
        <a href="/contact" class="border border-amber-300 text-amber-100 px-6 py-3 rounded-lg hover:bg-stone-700 transition-colors w-40 text-center">
          Find Us
        </a>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-5xl mx-auto px-4 py-12 grid md:grid-cols-2 gap-10 items-center">
    <div>
      <h2 class="text-3xl font-bold text-stone-800 mb-4">Good food, great company</h2>
      <p class="text-stone-600 leading-relaxed mb-4">
        Set in the charming old market town of Sturminster Newton, Poets Corner Café
        offers a wide choice of home-cooked food and drink at very reasonable prices.
        Whether you fancy a full English breakfast, a freshly made sandwich or toastie,
        a hearty baked potato, or our popular Mousaka — there's something here for everyone.
      </p>
      <p class="text-stone-600 leading-relaxed">
        Family-friendly, with indoor seating and a takeaway service.
        We're your perfect stop in the heart of the Blackmore Vale.
      </p>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <img src="https://images.unsplash.com/photo-1533089860892-a7c6f0a88666?w=400&q=80" alt="Full English breakfast" class="rounded-xl object-cover w-full h-40" />
      <img src="https://images.unsplash.com/photo-1528735602780-2552fd46c7af?w=400&q=80" alt="Toasted sandwich" class="rounded-xl object-cover w-full h-40" />
      <img src="https://images.unsplash.com/photo-1559054663-e8d23213f55c?w=400&q=80" alt="Cafe sandwich" class="rounded-xl object-cover w-full h-40" />
      <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=400&q=80" alt="Burger" class="rounded-xl object-cover w-full h-40" />
    </div>
  </section>

  <!-- Highlights -->
  <section class="bg-stone-100 py-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center text-stone-800 mb-8">What we offer</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { icon: '🍳', title: 'All-Day Breakfast', desc: 'Full English or vegetarian breakfast, bacon, sausage and egg rolls.' },
          { icon: '🥪', title: 'Sandwiches & Toasties', desc: 'Freshly made sandwiches and toasted sandwiches, all with coleslaw & salad.' },
          { icon: '🍽️', title: 'Hot Dishes', desc: 'Baked potatoes, pasta, burgers, platters and our famous Mousaka.' },
          { icon: '☕', title: 'Drinks', desc: 'Teas, coffees, hot chocolate, milkshakes and cold drinks.' },
        ].map(({ icon, title, desc }) => (
          <div class="bg-white rounded-xl p-6 text-center shadow-sm">
            <div class="text-4xl mb-3">{icon}</div>
            <h3 class="font-semibold text-stone-800 mb-1">{title}</h3>
            <p class="text-stone-500 text-sm">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Come and see us -->
  <section class="max-w-5xl mx-auto px-4 py-12 text-center">
    <h2 class="text-3xl font-bold text-stone-800 mb-3">Come and see us</h2>
    <p class="text-stone-600 mb-1">
      <strong>Station Road, Sturminster Newton, Dorset, DT10 1BB</strong>
    </p>
    <p class="text-stone-500 mb-6">Mon – Fri: 9 am – 3 pm &nbsp;·&nbsp; Sat: 9 am – 2 pm &nbsp;·&nbsp; Sun: Closed</p>
    <a href="/contact" class="inline-block bg-amber-400 text-stone-800 font-semibold px-6 py-3 rounded-lg hover:bg-amber-300 transition-colors">
      Get Directions &amp; Contact
    </a>
  </section>

</Base>
