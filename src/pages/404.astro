---
import Base from '../layouts/Base.astro'
---
<Base title="404 – Page not found">
  <main class="flex min-h-screen flex-col items-center justify-center gap-4 p-8 text-center">
    <h1 class="text-6xl font-bold text-gray-200">404</h1>
    <p class="text-lg text-gray-500">Page not found.</p>
    <a href="/" class="text-sm font-medium text-gray-700 underline underline-offset-2 hover:text-gray-900 transition-colors">
      Go home
    </a>
  </main>
</Base>
