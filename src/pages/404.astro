---
import Base from '../layouts/Base.astro'
---
<Base title="404 – Page not found">
  <main class="flex min-h-screen flex-col items-center justify-center gap-4 p-8 text-center">
    <p class="text-7xl">☕</p>
    <h1 class="text-4xl font-bold text-stone-800">Page not found</h1>
    <p class="text-stone-500 max-w-sm">
      Looks like this page has gone cold. Head back to the café and we'll get you sorted.
    </p>
    <a href="/" class="bg-amber-400 text-stone-800 font-semibold px-6 py-3 rounded-lg hover:bg-amber-300 transition-colors">
      Back to Home
    </a>
  </main>
</Base>
