---
import '@fontsource-variable/inter'

interface Props {
  title: string
  description?: string
  image?: string
  pageTitle?: string
}
const {
  title,
  description = 'Poets Corner Café, Sturminster Newton, Dorset. Breakfast, lunch and more in the heart of the Blackmore Vale.',
  image = 'https://images.unsplash.com/photo-1533089860892-a7c6f0a88666?w=1200&q=80',
  pageTitle,
} = Astro.props

const fullTitle = pageTitle ?? `${title} | Poets Corner Café`

const canonicalUrl = Astro.url.href

const nav = [
  { href: '/', label: 'Home' },
  { href: '/menu', label: 'Menu' },
  { href: '/sturminster-newton', label: 'Sturminster Newton' },
  { href: '/contact', label: 'Contact' },
]

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href)
---
<!doctype html>
<html lang="en" class="min-h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={image} />
    <style is:global>
      * { box-sizing: border-box; }
    </style>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-amber-50 text-stone-800 font-sans">

    <!-- Header / Nav -->
    <header class="bg-stone-800 text-amber-50 shadow-lg">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-4">
        <a href="/" class="flex flex-col leading-tight shrink-0">
          <span class="text-xl sm:text-2xl font-bold tracking-wide text-amber-300">Poets Corner Café</span>
          <span class="text-xs sm:text-sm text-amber-100/70">Sturminster Newton, Dorset</span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex flex-wrap gap-1">
          {nav.map(({ href, label }) => (
            <a
              href={href}
              class={`px-4 py-2 rounded-md text-sm font-medium transition-colors ${
                isActive(href)
                  ? 'bg-amber-400 text-stone-800'
                  : 'text-amber-100 hover:bg-stone-700'
              }`}
            >
              {label}
            </a>
          ))}
        </nav>

        <!-- Mobile burger button -->
        <button
          id="menu-btn"
          class="md:hidden flex flex-col justify-center items-center w-9 h-9 gap-1.5 rounded-md hover:bg-stone-700 transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <span class="burger-line block w-5 h-0.5 bg-amber-200 transition-all duration-300"></span>
          <span class="burger-line block w-5 h-0.5 bg-amber-200 transition-all duration-300"></span>
          <span class="burger-line block w-5 h-0.5 bg-amber-200 transition-all duration-300"></span>
        </button>
      </div>

      <!-- Mobile drawer -->
      <div
        id="mobile-menu"
        class="md:hidden hidden border-t border-stone-700"
      >
        <nav class="flex flex-col px-4 py-3 gap-1">
          {nav.map(({ href, label }) => (
            <a
              href={href}
              class={`px-4 py-2.5 rounded-md text-sm font-medium transition-colors ${
                isActive(href)
                  ? 'bg-amber-400 text-stone-800'
                  : 'text-amber-100 hover:bg-stone-700'
              }`}
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <script>
      const btn = document.getElementById('menu-btn')
      const menu = document.getElementById('mobile-menu')
      const lines = btn?.querySelectorAll('.burger-line') ?? []
      btn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false
        btn.setAttribute('aria-expanded', String(open))
        if (open) {
          lines[0]?.classList.add('rotate-45', 'translate-y-2')
          lines[1]?.classList.add('opacity-0')
          lines[2]?.classList.add('-rotate-45', '-translate-y-2')
        } else {
          lines[0]?.classList.remove('rotate-45', 'translate-y-2')
          lines[1]?.classList.remove('opacity-0')
          lines[2]?.classList.remove('-rotate-45', '-translate-y-2')
        }
      })
    </script>

    <slot />

    <!-- Footer -->
    <footer class="bg-stone-800 text-amber-100/70">
      <div class="max-w-5xl mx-auto px-4 py-8 grid sm:grid-cols-3 gap-6 text-sm">
        <div>
          <p class="font-semibold text-amber-300 mb-1">Poets Corner Café</p>
          <p>Station Road<br/>Sturminster Newton<br/>DT10 1BB</p>
        </div>
        <div>
          <p class="font-semibold text-amber-300 mb-1">Opening Hours</p>
          <p>Mon – Fri: 9 am – 3 pm<br/>Saturday: 9 am – 2 pm<br/>Sunday: Closed</p>
        </div>
        <div>
          <p class="font-semibold text-amber-300 mb-1">Get in Touch</p>
          <p><a href="tel:+441258473723" class="hover:text-amber-300 transition-colors">01258 473723</a></p>
        </div>
      </div>
      <div class="border-t border-stone-700 text-center py-3 text-xs text-stone-500">
        © {new Date().getFullYear()} Poets Corner Café. All rights reserved.
      </div>
    </footer>

  </body>
</html>
